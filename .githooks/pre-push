#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if ! command -v uv >/dev/null 2>&1; then
  echo "pre-push: 'uv' is required but not found. Install uv: https://docs.astral.sh/uv/" >&2
  exit 1
fi

echo "pre-push: running make lint"
make lint

echo "pre-push: running make typecheck"
make typecheck
